# Copy to server/.env and fill in your values.
# The frontend reads API_BASE_URL from lib/api.ts, not from .env.

# Server port
PORT=3001

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (public, used by frontend)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server only, keep private)
SUPABASE_SECRET_KEY=your-service-role-key-here

# JWT signing secret for auth tokens
JWT_SECRET=change-me-to-a-long-random-string

# Groq API key for syllabus analysis
GROQ_API_KEY=your-groq-api-key-here

# College Scorecard API key for program comparisons
# free key: https://api.data.gov/signup
SCORECARD_API_KEY=your-scorecard-api-key-here
